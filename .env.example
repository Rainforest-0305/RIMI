# 미리(MIRI) 환경변수 예시. 이 파일을 .env 로 복사해 값을 채우세요.
# 로컬 개발 시 config.py 는 kis-trading/.env 를 먼저 읽고, 로컬 .env 가 있으면 오버라이드합니다.
# 배포(Render/Docker) 시에는 아래 값을 플랫폼 환경변수로 주입하세요(레포에 커밋 금지).

# DART OpenAPI 인증키 (필수). https://opendart.fss.or.kr 에서 발급.
DART_API_KEY=

# 폴링 주기(초). 기본 300(5분).
GONGSI_POLL_SEC=300

# (선택) 텔레그램 테스트 채널 chat_id. 없으면 콘솔/파일 로그로만 알림.
# 실유저 브로드캐스트 금지 — 본인 테스트 채널 전용.
GONGSI_TEST_CHAT_ID=

# 텔레그램 봇 토큰. 없으면 봇 미기동. 실토큰 커밋 금지.
TELEGRAM_BOT_TOKEN=

# === X(트위터) 자동 게시 (x_poster.py) ===
# 실게시는 X_ENABLED=1 이고 아래 4종 키가 모두 있을 때만 도달. 기본은 dry-run(로그만).
# 키는 커밋 금지(.env* 는 .gitignore 제외). President 발급 대기.
X_ENABLED=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN_OAUTH1=
X_ACCESS_SECRET_OAUTH1=
# 쿼터 가드: Free 티어 월 500 대응 일 한도(기본 15). 텔레그램과 독립 카운터.
X_DAILY_LIMIT=15
# (선택) 실발송 없이 dry-run 로그만 강제(핵심 폴링 훅 활성화용). 1/true 로 켬.
X_DRYRUN=
